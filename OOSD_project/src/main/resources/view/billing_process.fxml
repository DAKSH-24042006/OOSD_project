<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="controller.BillingProcessController">
    <center>
        <VBox spacing="20" alignment="TOP_CENTER" styleClass="form-pane" maxWidth="600">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>
            <Label text="Guest Checkout &amp; Billing" styleClass="header-label" style="-fx-font-size: 24px;"/>
            
            <VBox spacing="10" alignment="CENTER_LEFT">
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="Booking ID:" prefWidth="150" style="-fx-font-weight: bold;"/>
                    <ComboBox fx:id="bookingIdList" prefWidth="250"/>
                </HBox>

                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="Guest Name:" prefWidth="150" style="-fx-font-weight: bold;"/>
                    <Label fx:id="guestNameLabel" text="-"/>
                </HBox>

                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="Room Info:" prefWidth="150" style="-fx-font-weight: bold;"/>
                    <Label fx:id="roomInfoLabel" text="-"/>
                </HBox>

                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="Duration:" prefWidth="150" style="-fx-font-weight: bold;"/>
                    <Label fx:id="stayDurationLabel" text="-"/>
                </HBox>

                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="Extra Costs:" prefWidth="150" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="extraCostField" text="0.0" prefWidth="250"/>
                </HBox>

                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="Discount %:" prefWidth="150" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="discountPercentField" text="0" prefWidth="250"/>
                </HBox>

                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="Tax 18%:" prefWidth="150" style="-fx-font-weight: bold;"/>
                    <Label fx:id="taxAmountLabel" text="\$0.00"/>
                </HBox>

                <Separator prefWidth="500"/>

                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="TOTAL:" prefWidth="150" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                    <Label fx:id="finalTotalLabel" text="-" style="-fx-font-size: 20px; -fx-text-fill: #ffd700; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>
            
            <Button text="COMPLETE CHECKOUT" onAction="#submitCheckout" prefWidth="300" styleClass="action-button"/>
        </VBox>
    </center>
</BorderPane>
