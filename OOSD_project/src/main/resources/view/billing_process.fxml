<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="controller.BillingProcessController">
    <center>
        <VBox spacing="25" alignment="TOP_CENTER" styleClass="form-pane" maxWidth="600">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>
            <Label text="Guest Checkout &amp; Billing" styleClass="header-label" style="-fx-font-size: 28px;"/>
            
            <VBox spacing="15" alignment="CENTER_LEFT">
                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label text="Select Booking ID:" style="-fx-font-weight: bold;" prefWidth="180"/>
                    <ComboBox fx:id="bookingIdList" prefWidth="250" promptText="Choose booking..."/>
                </HBox>

                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label text="Guest Name:" style="-fx-font-weight: bold;" prefWidth="180"/>
                    <Label fx:id="guestNameLabel" text="-" />
                </HBox>

                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label text="Room Category:" style="-fx-font-weight: bold;" prefWidth="180"/>
                    <Label fx:id="roomInfoLabel" text="-" />
                </HBox>

                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label text="Length of Stay:" style="-fx-font-weight: bold;" prefWidth="180"/>
                    <Label fx:id="stayDurationLabel" text="-" />
                </HBox>

                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label text="Extra Charges ($):" style="-fx-font-weight: bold;" prefWidth="180"/>
                    <TextField fx:id="extraCostField" text="0.0" prefWidth="250"/>
                </HBox>

                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label text="Applied Discount (%):" style="-fx-font-weight: bold;" prefWidth="180"/>
                    <TextField fx:id="discountPercentField" text="0" prefWidth="250"/>
                </HBox>

                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label text="Estimated Tax (18%):" style="-fx-font-weight: bold;" prefWidth="180"/>
                    <Label fx:id="taxAmountLabel" text="$0.00" />
                </HBox>

                <Separator prefWidth="500" style="-fx-padding: 10 0;"/>

                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label text="TOTAL PAYABLE:" style="-fx-font-weight: bold;" prefWidth="180"/>
                    <Label fx:id="finalTotalLabel" text="-" 
                           style="-fx-font-size: 24px; -fx-text-fill: #ffd700; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>
            
            <Button text="COMPLETE CHECKOUT" onAction="#submitCheckout" 
                    styleClass="action-button checkout-btn" prefWidth="300" 
                    style="-fx-font-size: 16px; -fx-padding: 15 30;"/>
        </VBox>
    </center>
</BorderPane>
