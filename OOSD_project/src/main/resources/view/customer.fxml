<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="controller.CustomerController" styleClass="main-container">
    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>
    <left>
        <VBox spacing="15" styleClass="form-pane" prefWidth="350">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <Label text="Customer Registration" styleClass="header-label"/>
            
            <VBox spacing="5">
                <Label text="Full Name"/>
                <TextField fx:id="txtName" promptText="Enter name"/>
            </VBox>
            
            <VBox spacing="5">
                <Label text="Phone Number"/>
                <TextField fx:id="txtPhone" promptText="Enter 10-digit phone"/>
            </VBox>
            
            <VBox spacing="5">
                <Label text="Email Address"/>
                <TextField fx:id="txtEmail" promptText="Enter email"/>
            </VBox>
            
            <VBox spacing="5">
                <Label text="Home Address"/>
                <TextArea fx:id="txtAddress" prefHeight="80" promptText="Enter address" styleClass="text-area"/>
            </VBox>
            
            <HBox spacing="10" alignment="CENTER">
                <Button text="Save" onAction="#handleSave" styleClass="action-button" prefWidth="100"/>
                <Button text="Update" onAction="#handleUpdate" styleClass="action-button" prefWidth="100" style="-fx-background-color: #ffd700; -fx-text-fill: black;"/>
                <Button text="Clear" onAction="#handleClear" styleClass="action-button" prefWidth="100" style="-fx-background-color: #2a2a2a;"/>
            </HBox>
        </VBox>
    </left>
    <center>
        <VBox spacing="15">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="Search Customers:" style="-fx-font-weight: bold;"/>
                <TextField fx:id="txtSearch" promptText="Search by name or phone..." prefWidth="400"/>
            </HBox>
            
            <TableView fx:id="tableCustomers" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colName" text="Name" prefWidth="200"/>
                    <TableColumn fx:id="colPhone" text="Phone" prefWidth="150"/>
                    <TableColumn fx:id="colEmail" text="Email" prefWidth="200"/>
                    <TableColumn fx:id="colAddress" text="Address" prefWidth="250"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
