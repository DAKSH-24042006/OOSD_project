<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="controller.CheckoutController">
    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>
    <center>
        <VBox spacing="20" alignment="CENTER" styleClass="form-pane" maxWidth="500" maxHeight="500">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>
            <Label text="Checkout &amp; Billing" styleClass="header-label"/>
            
            <GridPane hgap="15" vgap="15" alignment="CENTER">
                <Label text="Select Booking:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <ComboBox fx:id="cmbBooking" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="200"/>

                <Label text="Customer:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
                <Label fx:id="lblCustomerDetails" text="-" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Room:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;"/>
                <Label fx:id="lblRoomDetails" text="-" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label text="Total Days:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold;"/>
                <Label fx:id="lblDays" text="-" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="Total Amount:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight: bold;"/>
                <Label fx:id="lblTotal" text="-" GridPane.columnIndex="1" GridPane.rowIndex="4" style="-fx-font-size: 20px; -fx-text-fill: #ffd700; -fx-font-weight: bold;"/>
            </GridPane>
            
            <Button text="Complete Checkout" onAction="#handleCheckout" styleClass="action-button, checkout-btn">
                <VBox.margin>
                    <Insets top="20"/>
                </VBox.margin>
            </Button>
        </VBox>
    </center>
</BorderPane>
