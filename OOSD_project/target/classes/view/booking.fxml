<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="controller.BookingController">
    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>
    <left>
        <VBox spacing="10" alignment="TOP_CENTER" styleClass="form-pane">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <Label text="Create Booking" styleClass="header-label"/>
            
            <GridPane hgap="10" vgap="10">
                <Label text="Booking ID:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="txtBookingId" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="Customer:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <ComboBox fx:id="cmbCustomer" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Available Room:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <ComboBox fx:id="cmbRoom" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label text="Check In:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <DatePicker fx:id="dpCheckIn" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="Check Out:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <DatePicker fx:id="dpCheckOut" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                <Label text="Payment Status:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                <ComboBox fx:id="cmbPaymentStatus" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                <Label text="Payment Method:" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                <ComboBox fx:id="cmbPaymentMethod" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
            </GridPane>
            
            <Button text="Save Booking" onAction="#handleSaveBooking" styleClass="action-button"/>
        </VBox>
    </left>
    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="20" right="20" bottom="20" left="10"/>
            </padding>
            <Label text="Bookings List" styleClass="header-label"/>
            <TableView fx:id="tableBookings" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colBookingId" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colCustomerName" text="Customer" prefWidth="150"/>
                    <TableColumn fx:id="colRoomId" text="Room ID" prefWidth="80"/>
                    <TableColumn fx:id="colDates" text="Dates" prefWidth="250"/>
                    <TableColumn fx:id="colPaymentStatus" text="Status" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
