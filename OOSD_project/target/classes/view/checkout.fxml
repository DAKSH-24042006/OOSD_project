<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="controller.CheckoutBillController">
    <center>
        <VBox spacing="25" alignment="TOP_CENTER" styleClass="form-pane" maxWidth="600">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>
            <Label text="Checkout &amp; Billing" styleClass="header-label" style="-fx-font-size: 28px;"/>
            
            <VBox spacing="15" alignment="CENTER_LEFT">
                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label text="Select Booking ID:" style="-fx-font-weight: bold;" prefWidth="180"/>
                    <ComboBox fx:id="bookingSelector" prefWidth="250" promptText="Choose booking..."/>
                </HBox>

                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label text="Guest Name:" style="-fx-font-weight: bold;" prefWidth="180"/>
                    <Label fx:id="customerDisplay" text="-" />
                </HBox>

                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label text="Room Category:" style="-fx-font-weight: bold;" prefWidth="180"/>
                    <Label fx:id="roomDisplay" text="-" />
                </HBox>

                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label text="No. of Days:" style="-fx-font-weight: bold;" prefWidth="180"/>
                    <Label fx:id="daysDisplay" text="-" />
                </HBox>

                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label text="Extra Charges ($):" style="-fx-font-weight: bold;" prefWidth="180"/>
                    <TextField fx:id="extraChargesInput" text="0.0" prefWidth="250"/>
                </HBox>

                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label text="Discount (%):" style="-fx-font-weight: bold;" prefWidth="180"/>
                    <TextField fx:id="discountInput" text="0" prefWidth="250"/>
                </HBox>

                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label text="Tax Total (18%):" style="-fx-font-weight: bold;" prefWidth="180"/>
                    <Label fx:id="taxDisplay" text="$0.00" />
                </HBox>

                <Separator prefWidth="500" style="-fx-padding: 10 0;"/>

                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label text="Final Payable:" style="-fx-font-weight: bold;" prefWidth="180"/>
                    <Label fx:id="totalDisplay" text="-" 
                           style="-fx-font-size: 24px; -fx-text-fill: #ffd700; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>
            
            <Button text="FINALIZE CHECKOUT" onAction="#onCompleteCheckout" 
                    styleClass="action-button checkout-btn" prefWidth="300" 
                    style="-fx-font-size: 16px; -fx-padding: 15 30;"/>
        </VBox>
    </center>
</BorderPane>
